# Supabase Configuration (Required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Claude/Anthropic Integration (Optional)
# Leave empty to use mock AI responses in development
# To enable real AI responses in production, get a key from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Stripe Integration (Optional)
# Leave empty to use demo mode with simulated payments
# To enable real payments in production:
# 1. Create a Stripe account: https://stripe.com
# 2. Get your Secret Key from: https://dashboard.stripe.com/apikeys
# 3. Set up webhooks at: https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Notes:
# - The application runs fully locally WITHOUT these optional keys
# - Mock AI responses are used when ANTHROPIC_API_KEY is not set
# - Payment buttons show demo alerts when STRIPE_SECRET_KEY is not set
# - No API errors are thrown - everything degrades gracefully
